{
  "name": "devbrain",
  "version": "2.0.0",
  "description": "Offline Code Intelligence Platform — multi-agent RAG over local codebases with multimodal, P2P delegation, fine-tuning, and real-time monitoring, powered by QVAC SDK",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js --path ./",
    "client": "node src/p2p/client.js",
    "finetune": "node src/finetune/train.js",
    "monitor": "node src/index.js --path ./ --watch"
  },
  "keywords": ["qvac", "code-intelligence", "rag", "multi-agent", "offline", "p2p", "multimodal", "edge-ai", "fine-tuning"],
  "license": "Apache-2.0",
  "dependencies": {
    "@qvac/sdk": "^0.11.0",
    "express": "^5.1.0",
    "zod": "^3.25.36",
    "marked": "^15.0.0",
    "chokidar": "^4.0.0"
  }
}
